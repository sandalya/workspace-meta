[Unit]
Description=Garcia — Packaging Design Assistant
After=network.target

[Service]
Type=simple
User=sashok
WorkingDirectory=/home/sashok/.openclaw/workspace/garcia
EnvironmentFile=/home/sashok/.openclaw/workspace/garcia/.env
ExecStartPre=/bin/mkdir -p /run/user/1000/bot-locks
ExecStart=/usr/bin/flock -n /run/user/1000/bot-locks/garcia.lock /home/sashok/.openclaw/workspace/garcia/venv/bin/python main.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
